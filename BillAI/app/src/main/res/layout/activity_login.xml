<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res/auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light"
    android:padding="24dp">

    <!-- Logo / Brand -->
    <TextView
        android:id="@+id/tvBrand"
        style="@style/PolarisAppTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Bill AI"
        android:textSize="32sp"
        app:layout_constraintBottom_toTopOf="@+id/tvSub"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed" />

    <TextView
        android:id="@+id/tvSub"
        style="@style/PolarisAppSubText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Đăng nhập để đồng bộ hóa đơn"
        app:layout_constraintBottom_toTopOf="@+id/btnGoogleLogin"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvBrand" />

    <!-- Google Login Button -->
    <!-- Using CardView to support elevation easily or just the standard shape -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnGoogleLogin"
        style="@style/PolarisButton"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:layout_marginTop="48dp"
        android:text="Đăng nhập bằng Google"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvSub" />

</androidx.constraintlayout.widget.ConstraintLayout>
