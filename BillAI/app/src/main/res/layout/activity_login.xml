<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.45">

        <!-- Logo -->
        <ImageView
            android:id="@+id/ivLogo"
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:src="@drawable/ic_logo"
            android:contentDescription="Logo"
            android:layout_marginBottom="32dp"/>

        <TextView
            android:id="@+id/tvBrand"
            style="@style/PolarisAppTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome to Bill AI"
            android:textSize="28sp"
            android:letterSpacing="-0.03"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvSub"
            style="@style/PolarisAppSubText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Quản lý và quét hóa đơn thông minh"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="48dp"/>

        <!-- Google Login Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGoogleLogin"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Tiếp tục với Google"
            android:textAllCaps="false"
            android:textColor="@color/text_main"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium"
            app:cornerRadius="4dp"
            app:icon="@drawable/ic_google"
            app:iconGravity="textStart"
            app:iconPadding="16dp"
            app:iconTint="@null"
            app:strokeColor="@color/border_card"
            app:strokeWidth="1dp" 
            app:backgroundTint="@color/bg_card" />
            
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>