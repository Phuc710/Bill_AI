<?xml version="1.0" encoding="utf-8"?>
<!-- item_bill.xml: Card item cho RecyclerView danh sách hóa đơn -->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="4dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/border_card"
    app:cardBackgroundColor="@color/bg_card"
    android:foreground="?attr/selectableItemBackground">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Ảnh crop thumbnail -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardThumb"
            android:layout_width="56dp"
            android:layout_height="72dp"
            app:cardCornerRadius="2dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/border_card"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">
            
            <ImageView
                android:id="@+id/ivCroppedThumb"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="@color/bg_light"/>
                
        </com.google.android.material.card.MaterialCardView>

        <!-- Store name -->
        <TextView
            android:id="@+id/tvStoreName"
            style="@style/PolarisAppTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Tên cửa hàng"
            android:layout_marginStart="16dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/cardThumb"
            app:layout_constraintTop_toTopOf="@+id/cardThumb"/>

        <!-- Date -->
        <TextView
            android:id="@+id/tvDate"
            style="@style/PolarisAppSubText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="02/04/2026"
            android:layout_marginTop="4dp"
            android:layout_marginStart="16dp"
            app:layout_constraintEnd_toStartOf="@+id/tvTotal"
            app:layout_constraintStart_toEndOf="@+id/cardThumb"
            app:layout_constraintTop_toBottomOf="@+id/tvStoreName"/>

        <!-- Total amount (right aligned) -->
        <TextView
            android:id="@+id/tvTotal"
            style="@style/PolarisAppTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textColor="@color/accent_indigo"
            android:text="636,000đ"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/cardThumb"/>

        <!-- Status chip (failed bills) -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/error_red"
            android:visibility="gone"
            android:text="Cần kiểm tra"
            android:layout_marginTop="4dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvTotal"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
