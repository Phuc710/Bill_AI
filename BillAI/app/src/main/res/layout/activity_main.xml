<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/mainRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light"
    android:clipChildren="false"
    android:clipToPadding="false">

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/fragmentContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false" />

    <FrameLayout
        android:id="@+id/bottomDockContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginBottom="@dimen/main_bottom_bar_margin_bottom"
        android:clipChildren="false"
        android:clipToPadding="false">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/bottomAppBar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/main_bottom_bar_height"
            android:layout_gravity="bottom"
            android:layout_marginHorizontal="@dimen/main_bottom_bar_horizontal_margin"
            android:layout_marginTop="@dimen/main_bottom_bar_dock_offset"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="@dimen/main_bottom_bar_corner_radius"
            app:cardElevation="@dimen/main_bottom_bar_elevation"
            app:strokeColor="@color/divider"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="@dimen/main_bottom_bar_horizontal_padding"
                android:paddingTop="@dimen/main_bottom_bar_top_padding"
                android:paddingEnd="@dimen/main_bottom_bar_horizontal_padding"
                android:paddingBottom="@dimen/main_bottom_bar_bottom_padding">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/navHomeButton"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/main_nav_item_touch_height"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackgroundBorderless"
                        android:gravity="center"
                        android:orientation="vertical">

                        <FrameLayout
                            android:layout_width="@dimen/main_nav_icon_container_size"
                            android:layout_height="@dimen/main_nav_icon_container_size"
                            android:background="@drawable/bg_bottom_nav_item"
                            android:duplicateParentState="true"
                            android:foreground="?attr/selectableItemBackgroundBorderless">

                            <ImageView
                                android:layout_width="@dimen/main_nav_icon_size"
                                android:layout_height="@dimen/main_nav_icon_size"
                                android:layout_gravity="center"
                                android:contentDescription="@string/nav_home"
                                android:duplicateParentState="true"
                                app:tint="@color/bottom_nav_item_color"
                                app:srcCompat="@drawable/ic_nav_home" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:duplicateParentState="true"
                            android:includeFontPadding="false"
                            android:text="@string/nav_home"
                            android:textColor="@color/bottom_nav_item_color"
                            android:textSize="12.5sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/navBillsButton"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/main_nav_item_touch_height"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackgroundBorderless"
                        android:gravity="center"
                        android:orientation="vertical">

                        <FrameLayout
                            android:layout_width="@dimen/main_nav_icon_container_size"
                            android:layout_height="@dimen/main_nav_icon_container_size"
                            android:background="@drawable/bg_bottom_nav_item"
                            android:duplicateParentState="true"
                            android:foreground="?attr/selectableItemBackgroundBorderless">

                            <ImageView
                                android:layout_width="@dimen/main_nav_icon_size"
                                android:layout_height="@dimen/main_nav_icon_size"
                                android:layout_gravity="center"
                                android:contentDescription="@string/nav_bills"
                                android:duplicateParentState="true"
                                app:tint="@color/bottom_nav_item_color"
                                app:srcCompat="@drawable/ic_nav_receipt" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:duplicateParentState="true"
                            android:includeFontPadding="false"
                            android:text="@string/nav_bills"
                            android:textColor="@color/bottom_nav_item_color"
                            android:textSize="12.5sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <Space
                    android:layout_width="@dimen/main_bottom_bar_center_gap"
                    android:layout_height="1dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/navAnalyticsButton"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/main_nav_item_touch_height"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackgroundBorderless"
                        android:gravity="center"
                        android:orientation="vertical">

                        <FrameLayout
                            android:layout_width="@dimen/main_nav_icon_container_size"
                            android:layout_height="@dimen/main_nav_icon_container_size"
                            android:background="@drawable/bg_bottom_nav_item"
                            android:duplicateParentState="true"
                            android:foreground="?attr/selectableItemBackgroundBorderless">

                            <ImageView
                                android:layout_width="@dimen/main_nav_icon_size"
                                android:layout_height="@dimen/main_nav_icon_size"
                                android:layout_gravity="center"
                                android:contentDescription="@string/nav_analytics"
                                android:duplicateParentState="true"
                                app:tint="@color/bottom_nav_item_color"
                                app:srcCompat="@drawable/ic_nav_chart" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:duplicateParentState="true"
                            android:includeFontPadding="false"
                            android:text="@string/nav_analytics"
                            android:textColor="@color/bottom_nav_item_color"
                            android:textSize="12.5sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/navProfileButton"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/main_nav_item_touch_height"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackgroundBorderless"
                        android:gravity="center"
                        android:orientation="vertical">

                        <FrameLayout
                            android:layout_width="@dimen/main_nav_icon_container_size"
                            android:layout_height="@dimen/main_nav_icon_container_size"
                            android:background="@drawable/bg_bottom_nav_item"
                            android:duplicateParentState="true"
                            android:foreground="?attr/selectableItemBackgroundBorderless">

                            <ImageView
                                android:layout_width="@dimen/main_nav_icon_size"
                                android:layout_height="@dimen/main_nav_icon_size"
                                android:layout_gravity="center"
                                android:contentDescription="@string/nav_profile"
                                android:duplicateParentState="true"
                                app:tint="@color/bottom_nav_item_color"
                                app:srcCompat="@drawable/ic_nav_profile" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:duplicateParentState="true"
                            android:includeFontPadding="false"
                            android:text="@string/nav_profile"
                            android:textColor="@color/bottom_nav_item_color"
                            android:textSize="12.5sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnScanFab"
            android:layout_width="@dimen/main_scan_fab_size"
            android:layout_height="@dimen/main_scan_fab_size"
            android:layout_gravity="top|center_horizontal"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            app:cardBackgroundColor="@color/nav_scan_bg"
            app:cardCornerRadius="@dimen/main_scan_fab_corner_radius"
            app:cardElevation="@dimen/main_scan_fab_elevation"
            app:rippleColor="@color/accent_sky_soft"
            app:strokeColor="@color/bg_card"
            app:strokeWidth="2dp">

            <ImageView
                android:layout_width="@dimen/main_scan_icon_size"
                android:layout_height="@dimen/main_scan_icon_size"
                android:layout_gravity="center"
                android:contentDescription="@string/nav_scan"
                app:srcCompat="@drawable/qr_code_scanner_24" />
        </com.google.android.material.card.MaterialCardView>

    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
