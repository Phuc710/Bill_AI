<?xml version="1.0" encoding="utf-8"?>
<!-- ScanFragment: Chọn ảnh từ gallery hoặc chụp ảnh, rồi upload -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light">

    <!-- Header -->
    <TextView
        android:id="@+id/tvHeader"
        style="@style/PolarisAppTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Quét hóa đơn"
        android:paddingHorizontal="24dp"
        android:paddingTop="28dp"
        android:paddingBottom="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <TextView
        android:id="@+id/tvVersion"
        style="@style/PolarisAppSubText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Bill AI v1.0.0"
        android:textSize="12sp"
        android:textColor="@color/accent_indigo"
        android:paddingHorizontal="24dp"
        android:paddingTop="32dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <!-- Upload/Preview Area (Dropzone style) -->
    <FrameLayout
        android:id="@+id/uploadArea"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="24dp"
        android:background="@drawable/bg_dashed_border"
        app:layout_constraintBottom_toTopOf="@+id/cardActions"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvHeader">

        <!-- Empty State Hint -->
        <LinearLayout
            android:id="@+id/layoutHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_gravity="center"
            android:gravity="center">
            
            <FrameLayout
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="@drawable/bg_card"
                android:backgroundTint="@color/accent_indigo_soft"
                app:cardCornerRadius="4dp"
                android:layout_marginBottom="16dp">
                
                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/ic_menu_camera"
                    app:tint="@color/accent_indigo"/>
            </FrameLayout>
                
            <TextView
                style="@style/PolarisAppTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dropzone"
                android:textSize="18sp"
                android:textColor="@color/text_main"
                android:gravity="center"/>
                
            <TextView
                android:id="@+id/tvHint"
                style="@style/PolarisAppSubText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chọn hoặc chụp ảnh sắc nét"
                android:layout_marginTop="4dp"
                android:gravity="center"/>
        </LinearLayout>

        <!-- Preview Image -->
        <ImageView
            android:id="@+id/ivPreview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:background="@android:color/transparent"
            android:contentDescription="Preview ảnh hóa đơn"
            android:clipToOutline="true"/>
        
        <!-- Processing overlay (visible when uploading) -->
        <LinearLayout
            android:id="@+id/layoutProcessing"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#DBFAFAFA"
            android:visibility="gone">

            <ProgressBar
                style="?android:attr/progressBarStyle"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:indeterminateTint="@color/accent_indigo"/>

            <TextView
                android:id="@+id/tvProcessingStep"
                style="@style/PolarisAppTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đang xử lý..."
                android:textColor="@color/accent_indigo"
                android:textSize="15sp"
                android:layout_marginTop="16dp"/>
        </LinearLayout>
    </FrameLayout>

    <!-- Action Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="32dp"
        app:cardCornerRadius="4dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/bg_card"
        app:strokeWidth="1dp"
        app:strokeColor="@color/border_card"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Gallery Button -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnPickGallery"
                style="@style/PolarisButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Chọn từ thư viện"/>

            <!-- Camera Button -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnCamera"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:text="Chụp ảnh"
                android:background="@drawable/bg_outline_button"
                android:textColor="@color/text_main"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:letterSpacing="0.01"
                android:textSize="15sp"/>

            <!-- Upload Button -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnUpload"
                style="@style/PolarisButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:backgroundTint="@color/accent_indigo"
                android:text="✅  Xử lý hóa đơn"
                android:visibility="gone"/>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
