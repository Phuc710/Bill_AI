<?xml version="1.0" encoding="utf-8"?>
<!-- item_bill_item.xml: 1 hàng trong danh sách món của hóa đơn -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingVertical="6dp"
    android:gravity="center_vertical">

    <!-- Item name -->
    <TextView
        android:id="@+id/tvItemName"
        style="@style/PolarisAppSubText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textColor="@color/text_main"
        android:text="@string/placeholder_item_name"/>

    <!-- Quantity -->
    <TextView
        android:id="@+id/tvItemQty"
        style="@style/PolarisAppSubText"
        android:layout_width="36dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/placeholder_item_qty"/>

    <!-- Unit price -->
    <TextView
        android:id="@+id/tvItemUnitPrice"
        style="@style/PolarisAppSubText"
        android:layout_width="80dp"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:text="@string/placeholder_amount"/>

    <!-- Total price -->
    <TextView
        android:id="@+id/tvItemTotal"
        style="@style/PolarisAppTitle"
        android:layout_width="90dp"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:gravity="end"
        android:text="@string/placeholder_amount"/>

</LinearLayout>
