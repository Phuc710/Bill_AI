<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Polaris SaaS Button Outline/Solid -->
    <style name="PolarisButton" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/bg_polaris_button</item>
        <item name="android:textColor">@color/primary_button_text</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">16sp</item>
        <!-- Medium equivalent weight if font supports it or textStyle bold -->
        <item name="android:textStyle">normal</item>
        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingEnd">12dp</item>
        <item name="android:paddingTop">6dp</item>
        <item name="android:paddingBottom">6dp</item>
        <item name="fontFamily">sans-serif-medium</item>
    </style>

    <style name="PolarisCard">
        <item name="android:background">@drawable/bg_card</item>
        <item name="android:elevation">2dp</item>
    </style>
    
    <style name="PolarisAppTitle">
        <item name="android:textColor">@color/text_main</item>
        <item name="android:textSize">22sp</item>
        <item name="fontFamily">sans-serif-medium</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="PolarisAppSubText">
        <item name="android:textColor">@color/text_sub</item>
        <item name="android:textSize">14sp</item>
        <item name="fontFamily">sans-serif</item>
    </style>
</resources>
