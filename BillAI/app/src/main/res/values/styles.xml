<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="PolarisButton" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/bg_polaris_button</item>
        <item name="android:textColor">@color/primary_button_text</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <style name="PolarisCard">
        <item name="android:background">@drawable/bg_card</item>
        <item name="android:elevation">0dp</item>
    </style>

    <style name="PolarisAppTitle">
        <item name="android:textColor">@color/text_main</item>
        <item name="android:textSize">20sp</item>
        <item name="fontFamily">sans-serif-medium</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <style name="PolarisAppSubText">
        <item name="android:textColor">@color/text_sub</item>
        <item name="android:textSize">14sp</item>
        <item name="fontFamily">sans-serif</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <style name="PolarisHeroTitle" parent="PolarisAppTitle">
        <item name="android:textSize">32sp</item>
    </style>

    <style name="PolarisPageTitle" parent="PolarisHeroTitle">
        <item name="android:textColor">@color/accent_sky</item>
        <item name="android:textSize">34sp</item>
    </style>

    <style name="PolarisPageSubtitle" parent="PolarisAppSubText">
        <item name="android:textColor">@color/text_main</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="PolarisEyebrow">
        <item name="android:textColor">@color/accent_sky</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="fontFamily">sans-serif-medium</item>
    </style>

    <style name="PolarisStepTitle" parent="PolarisAppTitle">
        <item name="android:textSize">18sp</item>
    </style>

    <style name="PolarisSplashTitle" parent="PolarisAppTitle">
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textSize">34sp</item>
    </style>

    <style name="PolarisSplashSubText" parent="PolarisAppSubText">
        <item name="android:textColor">#B6C7F8</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="PolarisStatusWarning">
        <item name="android:background">@color/warning_bg</item>
        <item name="android:textColor">@color/warning_text</item>
        <item name="android:padding">12dp</item>
        <item name="android:textSize">13sp</item>
        <item name="fontFamily">sans-serif-medium</item>
    </style>

    <style name="PolarisDataLabel">
        <item name="android:textColor">@color/text_sub</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
        <item name="fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.06</item>
    </style>

    <style name="BottomBarShapeAppearanceOverlay">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">30dp</item>
        <item name="cornerSizeTopRight">30dp</item>
        <item name="cornerSizeBottomLeft">30dp</item>
        <item name="cornerSizeBottomRight">30dp</item>
    </style>
</resources>
