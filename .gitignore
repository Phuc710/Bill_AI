# Bill AI — Python gitignore

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Environments
.env
.env.*
!.env.example
venv/
env/
.venv/

# Models (large binary files — track separately via Git LFS if needed)
models/*.pt
models/*.onnx
models/*.engine

# Outputs and logs (runtime artifacts)
logs/
outputs/

# Test images (optional — remove if you want to track them)
*.jpg
*.jpeg
*.png
*.bmp
*.webp
!api/static/
!frontend/

# PaddleOCR auto-downloaded model cache
.paddleocr/
inference/

# Environment & Secrets (CRITICAL)
.env
.env.*
venv/
env/
ENV/
*.venv/
.venv/
.python-version

# IDE
.vscode/
.idea/
*.swp
*.swo
*.iml
.classpath
.project
.settings/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Build / dist
dist/
build/
*.egg-info/

# Ignore Mobile Project (Backend repository only)
BillAI_mobile/
