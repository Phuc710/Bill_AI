# Security
API_SECRET_KEY=replace-with-strong-api-key

# Groq
GROQ_API_KEY=replace-with-groq-key
GROQ_MODEL=llama-3.3-70b-versatile

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=replace-with-service-role-key
SUPABASE_BUCKET=Bills

# Optional tuning
MAX_IMAGE_BYTES=10485760
MAX_INPUT_SIDE=2600
OCR_MIN_CONF=0.35
